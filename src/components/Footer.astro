<footer>
  <div class="inner footer-inner">
    <a href="/" class="logo">Code <span>Cowboys</span></a>
    <div class="footer-links">
      <a href="/#apps">Apps</a>
      <a href="/#about">About</a>
      <a href="mailto:hello@code-cowboys.com">Contact</a>
    </div>
    <p>© 2026 Code Cowboys LLC · Michigan</p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid rgba(180,140,60,0.1);
    padding: 28px 0;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 16px;
    font-weight: 900;
    color: var(--text);
  }
  .logo span { color: var(--gold); }

  .footer-links {
    display: flex;
    gap: 22px;
  }

  .footer-links a {
    font-size: 12px;
    color: #3a2c1a;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--text-dim); }

  footer p { font-size: 12px; color: #3a2c1a; }

  @media (max-width: 768px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>